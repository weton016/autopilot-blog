{
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:secret": "node -e \"process.stdout.write('CRON_SECRET=' + require('crypto').randomBytes(32).toString('hex') + '\\n')\"",
    "cron:weekly": "curl -s -X POST ${WEBSITE_URL:-http://localhost:3000}/api/cron/weekly-scheduler -H \"Authorization: Bearer ${CRON_SECRET}\" | npx --yes prettyjson",
    "cron:daily": "curl -s -X POST ${WEBSITE_URL:-http://localhost:3000}/api/cron/daily-executor -H \"Authorization: Bearer ${CRON_SECRET}\" | npx --yes prettyjson"
  },
